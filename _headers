/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob: data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; worker-src 'self'; manifest-src 'self'; upgrade-insecure-requests
  # NOTA: challenges.cloudflare.com permanece em script-src/connect-src/frame-src
  # mesmo com o widget removido do HTML — basta reincluir <script src=".../turnstile/v0/api.js">
  # e o <div class="cf-turnstile"> pra reativar sem mexer em CSP.
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(self), camera=(self), geolocation=(self), payment=(self), accelerometer=(), gyroscope=(), magnetometer=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# index.html nunca deve ser cacheado pelo CDN/browser sem revalidação
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/portal/index.html
  Cache-Control: public, max-age=0, must-revalidate

# SEO files
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400

# Service worker precisa ser servido com escopo amplo
/sw.js
  Service-Worker-Allowed: /
  Cache-Control: public, max-age=0, must-revalidate

# Assets versionados (com ?v=) podem ter cache longo
/head.js
  Cache-Control: public, max-age=31536000, immutable
/app.js
  Cache-Control: public, max-age=31536000, immutable
/db.js
  Cache-Control: public, max-age=31536000, immutable
/validators.js
  Cache-Control: public, max-age=31536000, immutable
/errors.js
  Cache-Control: public, max-age=31536000, immutable
/logger.js
  Cache-Control: public, max-age=31536000, immutable
/policies.js
  Cache-Control: public, max-age=31536000, immutable
/config.js
  Cache-Control: public, max-age=31536000, immutable
/utils.js
  Cache-Control: public, max-age=31536000, immutable
/modules/*
  Cache-Control: public, max-age=31536000, immutable
/supabase.js
  Cache-Control: public, max-age=31536000, immutable
/jspdf.umd.min.js
  Cache-Control: public, max-age=31536000, immutable
/portal/app.js
  Cache-Control: public, max-age=31536000, immutable
/portal/react.production.min.js
  Cache-Control: public, max-age=31536000, immutable
/portal/react-dom.production.min.js
  Cache-Control: public, max-age=31536000, immutable
/leaflet.js
  Cache-Control: public, max-age=31536000, immutable
/leaflet.css
  Cache-Control: public, max-age=31536000, immutable

# Fontes auto-hospedadas (woff2 imutáveis — nome do arquivo muda se trocar)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Templates de referência da Arte IG — cache longo (mudança rara, troca de arquivo invalida)
/style-refs/*
  Cache-Control: public, max-age=604800

# Endpoints da API: nunca cachear + CORS restrito ao próprio domínio
/api/*
  Cache-Control: no-store
  Access-Control-Allow-Origin: https://queroumacor.com.br
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
  Access-Control-Max-Age: 600
  Vary: Origin
