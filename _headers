/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://challenges.cloudflare.com https://*.sentry-cdn.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob: data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://challenges.cloudflare.com https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://sentry.io https://*.sentry.io https://cdn.jsdelivr.net https://storage.googleapis.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(self), camera=(self), geolocation=(self), payment=(self), accelerometer=(), gyroscope=(), magnetometer=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Portal admin (vanilla, ainda não portado pro Next)
# As 3 variações de path (bare dir, com barra e index.html explícito) precisam
# da mesma regra no-cache — senão acessar /portal/ servia um index.html antigo
# de cache, que continuava apontando pro app.js?v= velho mesmo após deploy.
/portal
  Cache-Control: public, max-age=0, must-revalidate
/portal/
  Cache-Control: public, max-age=0, must-revalidate
/portal/index.html
  Cache-Control: public, max-age=0, must-revalidate
/portal/app.js
  Cache-Control: public, max-age=31536000, immutable
/portal/react.production.min.js
  Cache-Control: public, max-age=31536000, immutable
/portal/react-dom.production.min.js
  Cache-Control: public, max-age=31536000, immutable

# SEO files
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400

# Service worker — killswitch que limpa caches antigos do vanilla.
/sw.js
  Service-Worker-Allowed: /
  Cache-Control: public, max-age=0, must-revalidate

# Digital Asset Links — verificação de domínio pra TWA Android (Play Store).
/.well-known/assetlinks.json
  Content-Type: application/json
  Cache-Control: public, max-age=86400

# Manifest do PWA — TWA precisa pra reconhecer o app
/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=300

# Fontes auto-hospedadas (woff2 imutáveis — nome do arquivo muda se trocar)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Templates de referência da Arte IG — cache longo (mudança rara)
/style-refs/*
  Cache-Control: public, max-age=604800

# Imagens de produtos (estáticas, URLs estáveis)
/products/*
  Cache-Control: public, max-age=2592000

# Endpoints da API: nunca cachear + CORS restrito ao próprio domínio
/api/*
  Cache-Control: no-store
  Access-Control-Allow-Origin: https://queroumacor.com.br
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
  Access-Control-Max-Age: 600
  Vary: Origin
