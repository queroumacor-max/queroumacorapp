{
  "name": "queroumacorapp",
  "version": "1.0.0",
  "private": true,
  "description": "QueroUmaCor — PWA brasileira para contratar pintores, grafiteiros e funileiros",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "build:portal": "node scripts/build-portal.js",
    "check:deps": "node scripts/check-deps.js",
    "lint": "eslint . --ext .js,.cjs",
    "lint:strict": "eslint . --ext .js,.cjs --max-warnings 0",
    "lint:conventions": "node scripts/check-conventions.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^4.1.7",
    "@babel/standalone": "^7.24.0",
    "@playwright/test": "^1.48.0",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3"
  }
}
