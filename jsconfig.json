{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "checkJs": false,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["**/*.js", "**/*.d.ts"],
  "exclude": ["node_modules", "supabase.js", "leaflet.js", "jspdf.umd.min.js", "scripts/**"]
}
